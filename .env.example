PORT=3000
NODE_ENV=development

# ============================================================
# JARVIS BRAIN — pluggable LLM provider (used by `npm run jarvis`)
# Pick ONE provider, then fill in the matching block below.
# ============================================================
BRAIN_PROVIDER=nvidia   # nvidia | openrouter | gemini | ollama | openai

# --- nvidia (GPT-OSS-120B) ---
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=openai/gpt-oss-120b

# --- openrouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- gemini (OpenAI-compatible endpoint) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- ollama (local, no key needed) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=replace_with_a_strong_secret

REDIS_URL=redis://localhost:6379
QUEUE_CONCURRENCY=3

OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4

DISCORD_BOT_TOKEN=
NVIDIA_API_KEY=
VOICE_TTS_PROVIDER=macos
USE_NVIDIA=true
USE_OLLAMA_FALLBACK=false
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=openai/gpt-oss-120b
PARAKEET_API_KEY=
PARAKEET_MODEL=parakeet-tdt-0.6b-v2
VOICE_ENABLED=trueyour_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id

SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=multi-agent@yourdomain.com
EMAIL_TO=team@yourdomain.com
