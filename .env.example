PORT=3000
NODE_ENV=development

GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=replace_with_a_strong_secret

REDIS_URL=redis://localhost:6379
QUEUE_CONCURRENCY=3

OPENAI_API_KEY=sk-your_openai_key_here
